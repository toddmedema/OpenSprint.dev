# Dependencies
node_modules
node_modules/

# Build output
dist/
build/
!packages/electron/build/
packages/electron/build/*
!packages/electron/build/entitlements.mac.plist
!packages/electron/build/entitlements.mac.inherit.plist
!packages/electron/build/OpenSprint.icon/
!packages/electron/build/OpenSprint.icon/**

# Electron desktop (generated by build:desktop)
packages/electron/desktop-resources/
packages/electron/dist/
*.tsbuildinfo

# packages/shared build artifacts (generated for production only)
packages/shared/dist/
packages/shared/tsconfig.tsbuildinfo

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
.cursor/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/

# CI / local generated reports (Vitest junit/json, test-timings, etc.)
artifacts/

# Vitest native Postgres URL and run ID (generated by global-setup)
packages/backend/.vitest-postgres-url
packages/backend/.vitest-run-id
packages/backend/.vitest-postgres-container-id

# Vite
packages/frontend/.vite/

# Open Sprint runtime data (local only); feedback/counters/events/stats/deployments are in DB
# Settings live in global store (~/.opensprint/settings.json), not per-repo
.opensprint/*.json
!.opensprint/merge-toolchain.json
.opensprint/settings.json
.opensprint/active/
.opensprint/conversations/
.opensprint/agent-images/
.opensprint/sessions/
.opensprint/orchestrator-state.json
.opensprint/pending-commits.json
.opensprint/runtime/
.opensprint/merge-result.json
packages/backend/.opensprint/

# Temporary files
*.tmp
*.bak

.opensprint/worktrees/

# SQLite in-memory DB artifact (must never be tracked; breaks Windows checkout)
:memory:
